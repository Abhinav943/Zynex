{
  "name": "@abhinav943/zynex",
  "version": "1.0.4",
  "description": "A zero-dependency, detailed validation engine for Emails, Passwords, and URLs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "validator",
    "email",
    "password",
    "url",
    "validation",
    "typescript"
  ],
  "author": "Abhinav",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "**/*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
